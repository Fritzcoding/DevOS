# DevOS Lite local environment template.
# Copy this file to .env.local and fill only the values you need.
# Never commit .env.local or any other .env* file with real secrets.

# Cloud AI. You can also enter this from the in-app AI Settings screen.
GEMINI_API_KEY=

# Optional aliases supported by the AI client.
GOOGLE_API_KEY=
VITE_GEMINI_API_KEY=

# Optional model override for Gemini-compatible cloud setup.
GEMINI_MODEL=gemini-3.5-flash

# Local AI uses Ollama settings from the app UI; no .env value is required.
