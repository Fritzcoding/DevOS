{
  "name": "devops-lite",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "lint": "eslint src --ext .ts,.tsx",
  "format": "prettier --write src",
  "scripts": {
    "compile:main": "tsc main.ts preload.ts --lib ES2022,DOM --module commonjs --target ES2022 --moduleResolution node --esModuleInterop --skipLibCheck",
    "dev": "npm run compile:main && concurrently \"vite\" \"cross-env NODE_ENV=development electron . --shimeji\"",
    "dev:shimeji": "npm run compile:main && concurrently \"vite\" \"electron . --shimeji\"",
    "dev:vite": "vite",
    "dev:watch": "concurrently \"npm run compile:main -- --watch\" \"vite\"",
    "build": "npm run compile:main && vite build && tsc --noEmit && npm run package:dist",
    "package:dist": "echo 'Application built successfully. Run: npm run dev' ",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@google/generative-ai": "^0.24.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fs-extra": "^11.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^4.24.0",
    "p-queue": "^9.2.0",
    "path-browserify": "^1.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.devopslite.app",
    "productName": "DevOps Lite",
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {},
    "win": {
      "target": [
        "portable"
      ],
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": "./customSign.js"
    },
    "publish": null
  }
}
